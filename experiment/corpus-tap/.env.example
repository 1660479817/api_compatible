# Required
CORPUS_TAP_UPSTREAM=http://127.0.0.1:3000

# Token → user_id (production): read-only New API MySQL
# CORPUS_TAP_NEWAPI_MYSQL_DSN=readonly:password@tcp(127.0.0.1:3306)/newapi?parseTime=true

# Development only — maps all Bearer tokens to one user
CORPUS_TAP_DEV_USER_ID=1

# Metadata
# CORPUS_TAP_DATABASE_URL=postgres://corpus:corpus@127.0.0.1:5433/corpus?sslmode=disable
# make db-reset — Homebrew 可选超级用户：CORPUS_TAP_DATABASE_ADMIN_URL=postgres://$(whoami)@127.0.0.1:5432/postgres

# Blob: local dir (dev) or S3 (production)
CORPUS_TAP_LOCAL_DATA_DIR=./data
# CORPUS_TAP_S3_BUCKET=corpus-raw
# CORPUS_TAP_S3_REGION=us-east-1
# CORPUS_TAP_S3_ENDPOINT=http://127.0.0.1:9000
# CORPUS_TAP_S3_ACCESS_KEY=minio
# CORPUS_TAP_S3_SECRET_KEY=minio123
# CORPUS_TAP_S3_FORCE_PATH_STYLE=true

# Listen / mode
# CORPUS_TAP_LISTEN=:8443
# CORPUS_TAP_MODE=proxy-only

# Limits & retention
# CORPUS_TAP_MAX_BODY_BYTES=33554432
# CORPUS_TAP_MAX_STREAM_BYTES=67108864
# CORPUS_TAP_ON_OVERSIZE=truncate
# CORPUS_TAP_RETENTION_DAYS=90

# Deny lists (comma-separated ids)
# CORPUS_TAP_DENY_USER_IDS=
# CORPUS_TAP_DENY_TOKEN_IDS=

# Async store
# CORPUS_TAP_STORE_WORKERS=4
# CORPUS_TAP_STORE_QUEUE_SIZE=256

# Optional capture
# CORPUS_TAP_STORE_HEADERS=true
# CORPUS_TAP_STORE_SSE_RAW=true

# SSE: buffer in memory then spill to disk (P2)
# CORPUS_TAP_SSE_SPOOL_DIR=/tmp/corpus-spool
# CORPUS_TAP_SSE_SPOOL_MEM_BYTES=1048576

# Locked New API git digest (P1 baseline label)
# CORPUS_TAP_NEWAPI_DIGEST=b0ac042

# Enrich logs from New API MySQL (seconds; 0=off)
# CORPUS_TAP_ENRICH_INTERVAL_SEC=300

# Internal API
# CORPUS_TAP_ADMIN_KEY=change-me

# Deployment labels
# CORPUS_TAP_NEWAPI_IMAGE=v1.0.0-rc.9
# CORPUS_TAP_IMAGE=corpus-tap:dev
# Fixed deployment UUID (stable S3 prefix + PG rows across restarts)
# CORPUS_TAP_DEPLOYMENT_ID=00000000-0000-0000-0000-000000000001
