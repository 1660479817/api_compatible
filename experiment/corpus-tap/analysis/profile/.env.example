# Profile strategy (corpus-profile). DB/blob fall back to CORPUS_TAP_* when unset.

# Homebrew PG 常用 5432；Docker smoke 为 15433
CORPUS_PROFILE_DATABASE_URL=postgres://corpus:corpus@127.0.0.1:5432/corpus?sslmode=disable

CORPUS_PROFILE_LOCAL_DATA_DIR=./data
# CORPUS_PROFILE_S3_BUCKET=corpus-raw

CORPUS_PROFILE_LLM_BASE=http://127.0.0.1:4000
CORPUS_PROFILE_LLM_API_KEY=sk-operator-analysis
CORPUS_PROFILE_LLM_MODEL_L1=gpt-4o-mini
CORPUS_PROFILE_LLM_MODEL_L2=gpt-4o-mini
CORPUS_PROFILE_PROMPT_VERSION=v1

CORPUS_PROFILE_MIN_USER_CHARS=16
CORPUS_PROFILE_TRUNCATED_POLICY=allow
# CORPUS_PROFILE_EVAL_USER_IDS=1,2
# CORPUS_PROFILE_DENY_USER_IDS=

CORPUS_PROFILE_WORKERS=2
CORPUS_PROFILE_USER_INTERVAL_HOURS=24

CORPUS_PROFILE_LISTEN=:8444
CORPUS_PROFILE_ADMIN_KEY=change-me-profile
