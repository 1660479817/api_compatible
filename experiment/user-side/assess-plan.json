{
  "description": "Per-site test plan keyed by model family (Key + model id → primary Agent). URLs in sites.json.",
  "model_families": {
    "gpt": {
      "label": "GPT / OpenAI",
      "primary_agent": "codex",
      "layer2_wires": ["chat", "responses"],
      "layer3_agents": ["opencode", "codex"]
    },
    "anthropic": {
      "label": "Anthropic / Claude",
      "primary_agent": "claude",
      "layer2_wires": ["chat", "messages"],
      "layer3_agents": ["opencode", "claude"]
    },
    "other": {
      "label": "Other (OpenCode probe)",
      "primary_agent": "opencode",
      "layer2_wires": ["chat"],
      "layer3_agents": ["opencode"]
    }
  },
  "wire_labels": {
    "chat": "POST /v1/chat/completions (OpenCode)",
    "messages": "POST /v1/messages (Claude Code)",
    "responses": "POST /v1/responses (Codex)"
  },
  "smoke_mode": "relay",
  "smoke_timeout_sec": 180,
  "source_probe_timeout_sec": 120,
  "relay_probe_timeout_sec": 180,
  "smoke_scenarios": [
    {
      "id": "model_probe",
      "tags": ["anti-speculation", "identity"],
      "required": true,
      "model_probe": true,
      "prompt": "Respond with ONLY one JSON object — no markdown fences, no extra text. Required keys: \"model\" (your exact model identifier as you know it), \"release_date\" (ISO-8601 date when you were released, or \"unknown\"), \"knowledge_cutoff\" (your knowledge cutoff date, or \"unknown\"). Be factual about your identity; do not claim to be a different model.",
      "expect_json_keys": ["model", "release_date"],
      "expect_model_match": true
    },
    {
      "id": "explain",
      "tags": ["generation"],
      "required": true,
      "prompt": "Explain what an API gateway does in two short sentences.",
      "min_output_chars": 40
    },
    {
      "id": "structured",
      "tags": ["format"],
      "required": true,
      "prompt": "Reply with only one line of valid JSON: {\"status\":\"ok\"}",
      "expect_json_key": "status",
      "expect_json_value": "ok"
    },
    {
      "id": "code",
      "tags": ["code"],
      "required": true,
      "prompt": "Write a Python function named add that takes a and b. Output only the code block.",
      "expect_contains": "def add"
    },
    {
      "id": "tool",
      "tags": ["tool"],
      "required": false,
      "agent_only": true,
      "agents": {
        "opencode": {
          "prompt": "List the file names in the current directory only, one per line. Do not use markdown."
        },
        "codex": {
          "argv": [
            "exec",
            "Create /tmp/maas-smoke.txt containing TOOL_OK, then print TOOL_OK"
          ]
        },
        "claude": {
          "prompt": "Read CONFIG.md in the current directory and reply with its first markdown heading text only."
        }
      }
    }
  ],
  "sites": {
    "b.ai": {
      "families": {
        "anthropic": {
          "models": ["claude-haiku-4.5"],
          "layer3": {
            "models": {
              "claude": "claude-haiku-4.5",
              "opencode": "claude-haiku-4.5"
            }
          }
        },
        "other": {
          "models": ["kimi-k2.5"],
          "layer3": {
            "models": {
              "opencode": "kimi-k2.5"
            },
            "agents": ["opencode"]
          }
        }
      },
      "layer3": {
        "opencode": {
          "provider_id": "bai",
          "provider_name": "b.ai",
          "npm": "@ai-sdk/openai-compatible"
        }
      }
    },
    "ai.oai.red": {
      "families": {
        "gpt": {
          "models": ["gpt-5.5"],
          "layer3": {
            "models": {
              "codex": "gpt-5.5",
              "opencode": "gpt-5.5"
            },
            "opencode": {
              "provider_id": "oai-red",
              "provider_name": "ai.oai.red",
              "npm": "@ai-sdk/openai-compatible"
            }
          }
        }
      }
    },
    "sub2api.salus.icu": {
      "families": {
        "gpt": {
          "models": ["gpt-5.5"],
          "layer3": {
            "models": {
              "codex": "gpt-5.5",
              "opencode": "gpt-5.5"
            },
            "opencode": {
              "provider_id": "salus-sub2api",
              "provider_name": "sub2api.salus.icu",
              "npm": "@ai-sdk/openai-compatible"
            }
          }
        }
      }
    },
    "test_gpt_claude": {
      "families": {
        "gpt": {
          "models": ["AWS-GPT-5.4", "AWS-GPT-5.5"],
          "layer3": {
            "models": {
              "codex": "AWS-GPT-5.5",
              "opencode": "AWS-GPT-5.5"
            }
          }
        },
        "anthropic": {
          "primary_agent": "opencode",
          "models": ["AWS-Claude-Opus-4.7"],
          "layer3": {
            "models": {
              "opencode": "AWS-Claude-Opus-4.7"
            },
            "agents": ["opencode"]
          }
        }
      },
      "layer3": {
        "opencode": {
          "provider_id": "paratera-test-gpt-claude",
          "provider_name": "ai.paratera.com",
          "npm": "@ai-sdk/openai-compatible"
        }
      }
    }
  }
}
