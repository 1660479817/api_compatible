# Copy to .env and fill in API keys:
#   cp .env.example .env
#
# Variable names must match provider-profiles.json -> api_key_env.

EXAMPLE_OPENAI_KEY=sk-your-openai-compatible-key
EXAMPLE_ANTHROPIC_KEY=sk-your-anthropic-compatible-key

# Optional: HTTP/SOCKS proxy for provider API calls.
# Use socks5h so DNS resolves through the proxy.
# MAAS_PROXY=socks5h://127.0.0.1:10808
# MAAS_PROXY_SKIP=1

# Optional: override HTTP User-Agent when a provider blocks Python clients.
# MAAS_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0 Safari/537.36
